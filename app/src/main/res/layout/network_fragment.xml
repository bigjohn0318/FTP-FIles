<?xml version="1.0" encoding="utf-8"?>
<com.goodwy.filemanager.fragments.NetworkFragment xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/network_fragment"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/network_nested_scrollview"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <ImageView
                android:id="@+id/network_icon"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="12dp"
                android:src="@drawable/ic_network_vector"
                tools:ignore="ContentDescription" />

            <TextView
                android:id="@+id/network_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center_horizontal"
                android:text="@string/network_access_title"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/network_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_horizontal"
                android:text="@string/network_access_description"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/network_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center_horizontal"
                android:text="@string/network_access_status_stopped"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/network_address"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_horizontal"
                android:textIsSelectable="true"
                android:textSize="18sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/network_clients"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center_horizontal"
                android:textSize="13sp"
                android:visibility="gone" />

            <com.goodwy.commons.views.MyTextView
                android:id="@+id/network_copy_address"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:background="@drawable/ripple_all_corners_56dp"
                android:padding="10dp"
                android:text="@string/network_access_copy_address"
                android:textSize="14sp"
                android:visibility="gone" />

            <Button
                android:id="@+id/network_toggle_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="@string/network_access_start" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</com.goodwy.filemanager.fragments.NetworkFragment>
